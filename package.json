{
  "name": "dframe",
  "version": "0.1.0",
  "description": "Qt-like framework for TypeScript",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "build:dev": "tsc -p tsconfig.dev.json",
    "build:tests": "tsc -p tsconfig.tests.json",
    "dev": "webpack serve --mode development --env config=dev",
    "test": "npm run test:unit && npm run test:e2e",
    "test:unit": "jest --testPathIgnorePatterns=src/tests-e2e",
    "test:e2e": "tsc -p tsconfig.tests.json --noEmit && playwright test",
    "test:ui": "playwright test --ui",
    "test:debug": "npx playwright test --debug",
    "test:report": "npx playwright show-report",
    "test:setup": "playwright install --with-deps chromium",
    "test:server": "node scripts/test-server.js",
    "test:components": "playwright test src/tests-e2e/widgets/",
    "test:layouts": "playwright test src/tests-e2e/layout.spec.ts src/tests-e2e/horizontal-layout.spec.ts",
    "test:integration": "playwright test src/tests-e2e/integration/",
    "test:watch": "node scripts/watch-tests.js",
    "test:focused": "playwright test --grep=\"@focus\"",
    "test:headed": "playwright test --headed",
    "examples": "webpack serve --config webpack.examples.js --mode development --open",
    "showcase": "webpack serve --config webpack.examples.js --mode development --open"
  },
  "devDependencies": {
    "@playwright/test": "^1.40.1",
    "@testing-library/dom": "^9.3.4",
    "@types/jest": "^29.4.0",
    "@types/node": "^20.10.4",
    "@types/node-notifier": "^8.0.5",
    "chokidar": "^3.6.0",
    "html-webpack-plugin": "^5.6.3",
    "jest": "^29.4.2",
    "jest-environment-jsdom": "^29.7.0",
    "jest-watch-typeahead": "^2.2.2",
    "node-notifier": "^10.0.1",
    "ts-jest": "^29.0.5",
    "ts-loader": "^9.4.2",
    "typescript": "^4.9.5",
    "webpack": "^5.75.0",
    "webpack-cli": "^5.0.1",
    "webpack-dev-server": "^4.11.1"
  }
}
